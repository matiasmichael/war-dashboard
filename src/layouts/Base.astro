---
import type { Lang } from '../i18n/ui';
import { isRtl } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  generatedAt?: string;
  lang?: Lang;
}

const { title, description = 'Middle East Pulse — live conflict news and intelligence briefings from leading sources', generatedAt = new Date().toISOString(), lang = 'en' } = Astro.props;

const dir = isRtl(lang) ? 'rtl' : 'ltr';
const fontLink = lang === 'he'
  ? 'https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;600;700;800;900&family=Manrope:wght@400;500;600;700;800;900&display=swap'
  : 'https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800;900&display=swap';
---

<!DOCTYPE html>
<html lang={lang} dir={dir} data-theme="basecamp">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="data-generated-at" content={generatedAt}>
  <meta name="content-lang" content={lang}>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🔶</text></svg>">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="MEP">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href={fontLink} rel="stylesheet">
</head>
<body class:list={[
  "font-manrope bg-base-100 text-base-content leading-relaxed min-h-screen",
  lang === 'he' && "font-heebo"
]}>
  <slot />
</body>
</html>
