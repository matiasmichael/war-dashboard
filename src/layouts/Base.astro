---
import type { Lang } from '../i18n/ui';
import { isRtl } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  generatedAt?: string;
  lang?: Lang;
}

const { title, description = 'Middle East Pulse — live conflict news and intelligence briefings from leading sources', generatedAt = new Date().toISOString(), lang = 'en' } = Astro.props;

const dir = isRtl(lang) ? 'rtl' : 'ltr';
const fontLink = lang === 'he'
  ? 'https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;600;700;800;900&family=Manrope:wght@400;500;600;700;800;900&display=swap'
  : 'https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800;900&display=swap';
---

<!DOCTYPE html>
<html lang={lang} dir={dir} data-theme="basecamp">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="data-generated-at" content={generatedAt}>
  <meta name="content-lang" content={lang}>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🔶</text></svg>">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="MEP">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href={fontLink} rel="stylesheet">
  <script is:inline>
    (function() {
      try {
        const savedLang = localStorage.getItem('mep-lang');
        if (savedLang) {
          const path = window.location.pathname;
          const isHeRoute = path.startsWith('/he');
          if (savedLang === 'he' && !isHeRoute) {
            window.location.replace('/he' + path);
          } else if (savedLang === 'en' && isHeRoute) {
            window.location.replace(path.replace('/he', '') || '/');
          }
        }
      } catch (e) {}
    })();
  </script>
</head>
<body class:list={[
  "font-manrope bg-base-100 text-base-content leading-relaxed min-h-screen",
  lang === 'he' && "font-heebo"
]}>
  <!-- SPLASH OVERLAY -->
  <div id="mep-splash" class="fixed inset-0 z-[100] bg-header-brown text-white transition-opacity duration-300" style="display: none;">
    <div class="h-full flex flex-col items-center justify-center">
      <div class="mb-10 flex items-center gap-3">
        <span class="text-5xl drop-shadow-md">🔶</span>
        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-center drop-shadow-sm">Middle East Pulse</h1>
      </div>
      <p class="text-white/80 mb-10 text-lg font-medium tracking-wide uppercase text-center px-4">
        Choose your language<br/>
        <span class="font-heebo mt-2 block tracking-normal">בחר/י שפה</span>
      </p>
      <div class="flex gap-4 w-full max-w-[280px] flex-col sm:flex-row sm:max-w-md px-2">
        <button onclick="setLangAndContinue('en')" class="btn btn-lg bg-white/10 hover:bg-white/20 text-white border-white/20 w-full font-semibold shadow-sm">🇺🇸 English</button>
        <button onclick="setLangAndContinue('he')" class="btn btn-lg bg-white/10 hover:bg-white/20 text-white border-white/20 w-full font-heebo font-semibold shadow-sm" dir="rtl">🇮🇱 עברית</button>
      </div>
    </div>
  </div>

  <script is:inline>
    (function() {
      try {
        if (!localStorage.getItem('mep-lang')) {
          document.getElementById('mep-splash').style.display = 'block';
          document.body.style.overflow = 'hidden';
        }
      } catch (e) {}
    })();

    function setLangAndContinue(lang) {
      try {
        localStorage.setItem('mep-lang', lang);
      } catch (e) {}
      
      const splash = document.getElementById('mep-splash');
      if (splash) {
        splash.style.opacity = '0';
        setTimeout(() => {
          splash.style.display = 'none';
          document.body.style.overflow = '';
        }, 300);
      }
      
      const path = window.location.pathname;
      const isHeRoute = path.startsWith('/he');
      if (lang === 'he' && !isHeRoute) {
        window.location.href = '/he' + path;
      } else if (lang === 'en' && isHeRoute) {
        window.location.href = path.replace('/he', '') || '/';
      }
    }
  </script>

  <slot />
</body>
</html>
