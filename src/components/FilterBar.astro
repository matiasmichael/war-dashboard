---
interface FeedConfig {
  name: string;
  shortName: string;
  faviconDomain: string;
}

interface Props {
  sources: string[];
  feeds: FeedConfig[];
  articleCount: string;
}

const { sources, feeds, articleCount } = Astro.props;

function getFaviconUrl(domain: string): string {
  return `https://www.google.com/s2/favicons?domain=${domain}&sz=128`;
}

// Build shortName and favicon lookup from FEEDS config
const feedMap: Record<string, FeedConfig> = {};
for (const f of feeds) {
  feedMap[f.name] = f;
}
---

<div class="flex items-center justify-between py-3 pb-1">
  <span class="text-[0.72rem] font-semibold uppercase tracking-wider text-text-muted">Latest Articles</span>
  <span class="text-[0.72rem] font-normal text-text-muted" id="articleCount">{articleCount}</span>
</div>
<div class="flex flex-nowrap gap-1.5 py-1.5 overflow-x-auto scrollbar-none" id="articleFilterBar">
  <button class="btn btn-sm btn-outline btn-neutral rounded-full text-[0.78rem] font-semibold whitespace-nowrap flex-shrink-0 time-filter-btn" data-time="1h">Last 1h</button>
  <button class="btn btn-sm btn-outline btn-neutral rounded-full text-[0.78rem] font-semibold whitespace-nowrap flex-shrink-0 time-filter-btn" data-time="3h">Last 3h</button>
  <button class="btn btn-sm btn-outline btn-neutral rounded-full text-[0.78rem] font-semibold whitespace-nowrap flex-shrink-0 time-filter-btn" data-time="6h">Last 6h</button>
  <button class="btn btn-sm btn-outline btn-neutral rounded-full text-[0.78rem] font-semibold whitespace-nowrap flex-shrink-0 time-filter-btn" data-time="today">Today</button>
  <span class="w-px h-5 bg-base-300 flex-shrink-0 mx-0.5"></span>
  <button class="btn btn-sm btn-primary rounded-full text-[0.78rem] font-medium whitespace-nowrap flex-shrink-0 filter-btn" data-source="all">All</button>
  {sources.map(s => {
    const feed = feedMap[s];
    const shortName = feed ? feed.shortName : s;
    const logoUrl = feed ? getFaviconUrl(feed.faviconDomain) : '';
    return (
      <button class="btn btn-sm btn-ghost border border-base-300 rounded-full text-[0.78rem] font-medium whitespace-nowrap flex-shrink-0 text-text-muted hover:border-secondary hover:text-text-secondary filter-btn" data-source={s}>
        {logoUrl && <img src={logoUrl} class="w-4 h-4 rounded-full object-cover" alt="" />}
        {shortName}
      </button>
    );
  })}
</div>
