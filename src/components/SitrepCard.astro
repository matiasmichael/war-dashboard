---
interface TopUpdate {
  headline: string;
  source: string;
  time: string;
}

interface Props {
  sitrep: {
    summary: string;
    top_updates?: TopUpdate[];
    detailed_analysis?: string;
  } | null;
}

const { sitrep } = Astro.props;

function sanitizeHTML(html: string): string {
  if (!html) return '';
  let clean = html.replace(/\s+on\w+\s*=\s*["'][^"']*["']/gi, '');
  clean = clean.replace(/\s+on\w+\s*=\s*\S+/gi, '');
  clean = clean.replace(/\s+style\s*=\s*["'][^"']*["']/gi, '');
  clean = clean.replace(/<\/?(?!(?:strong|em|p|br|ul|li|h3|h4)\b)[a-z][a-z0-9]*\b[^>]*>/gi, '');
  return clean;
}

function escapeHtml(str: string): string {
  if (!str) return '';
  return str
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}
---

{sitrep ? (
  <div class="sitrep-card">
    <div class="sitrep-label">SITUATION REPORT</div>
    <div class="sitrep-summary" set:html={sanitizeHTML(sitrep.summary)} />
    <div class="sitrep-top-updates">
      {(sitrep.top_updates || []).map(u => (
        <div class="sitrep-update-card">
          <span class="sitrep-update-headline">{u.headline}</span>
          <span class="sitrep-update-meta">{u.source} · {u.time}</span>
        </div>
      ))}
    </div>
    <button class="sitrep-expand-btn" id="sitrepExpandBtn">
      <span class="sitrep-expand-label">See full briefing</span>
      <span class="sitrep-expand-chevron">›</span>
    </button>
    <div class="sitrep-detail" id="sitrepDetail">
      <p set:html={sanitizeHTML(sitrep.detailed_analysis || '')} />
    </div>
    <p class="sitrep-footer">AI-synthesized briefing · All sources</p>
  </div>
) : (
  <div class="sitrep-unavailable">
    <span class="sitrep-unavailable-icon">⚠️</span>
    <span>AI synthesis unavailable — showing articles only. The briefing will return on the next successful update.</span>
  </div>
)}

<script>
  const expandBtn = document.getElementById('sitrepExpandBtn');
  const detail = document.getElementById('sitrepDetail');
  if (expandBtn && detail) {
    expandBtn.addEventListener('click', () => {
      expandBtn.classList.toggle('open');
      detail.classList.toggle('open');
    });
  }
</script>
