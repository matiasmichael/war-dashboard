---
import { sanitizeHTML } from '../shared-utils.js';

interface TopUpdate {
  headline: string;
  source: string;
  time: string;
}

interface Props {
  sitrep: {
    summary: string;
    top_updates?: TopUpdate[];
    detailed_analysis?: string;
  } | null;
}

const { sitrep } = Astro.props;
---

{sitrep ? (
  <div class="card card-bordered bg-white shadow-md border-t-4 border-t-primary overflow-hidden mb-4">
    <div class="px-0 pt-0">
      <span class="badge badge-primary badge-sm rounded-none rounded-br-lg text-[0.68rem] font-bold uppercase tracking-wider">SITUATION REPORT</span>
    </div>
    <div class="card-body px-4 py-3 gap-2">
      <div class="text-[0.88rem] leading-relaxed text-text-secondary" set:html={sanitizeHTML(sitrep.summary)} />
    </div>
    <div class="collapse collapse-arrow border-t border-base-200">
      <input type="checkbox" id="sitrepCollapse" />
      <div class="collapse-title text-[0.78rem] font-medium text-text-muted min-h-0 py-2 px-4">
        See full briefing
      </div>
      <div class="collapse-content bg-base-100 px-4">
        <p class="text-[0.84rem] leading-relaxed text-text-secondary" set:html={sanitizeHTML(sitrep.detailed_analysis || '')} />
      </div>
    </div>
    <p class="text-[0.68rem] text-text-muted px-4 py-2 m-0 border-t border-base-200 bg-base-100">AI-synthesized briefing · All sources</p>
  </div>
) : (
  <div class="alert alert-warning mb-4">
    <span class="text-lg">⚠️</span>
    <span class="text-[0.82rem]">AI synthesis unavailable — showing articles only. The briefing will return on the next successful update.</span>
  </div>
)}
