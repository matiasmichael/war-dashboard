---
// Dark header with live dot, title, and nav — DaisyUI navbar
---

<div class="navbar bg-volcanic sticky top-0 z-50 px-0">
  <div class="max-w-[680px] mx-auto w-full flex flex-col">
    <div class="relative flex items-center justify-center px-4 py-2">
      <!-- Centered title -->
      <div class="flex flex-col items-center">
        <h1 class="text-[1.15rem] font-bold tracking-tight flex items-center gap-1.5 text-white m-0 whitespace-nowrap">
          Middle East Pulse
          <span class="live-pill live-pill-fresh" id="livePill">LIVE</span>
        </h1>
        <span class="text-[0.7rem] font-normal text-white/50" id="headerFreshness">🇮🇱 IDT</span>
      </div>
      <!-- Archive icon button (top right) -->
      <a href="/archive" class="btn btn-sm btn-ghost btn-square text-white/70 hover:text-white bg-white/8 hover:bg-white/15 rounded-lg absolute right-4 min-h-[36px] min-w-[36px]" title="Archive">🗓️</a>
    </div>
    <div class="h-[3px] bg-gradient-to-r from-bc-orange to-bc-gold"></div>
  </div>
</div>
