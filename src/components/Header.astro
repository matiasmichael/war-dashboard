---
// Dark header with live dot, title, and nav — DaisyUI navbar
---

<div class="navbar bg-volcanic sticky top-0 z-50 px-0">
  <div class="max-w-[680px] mx-auto w-full flex flex-col">
    <div class="flex items-center justify-between px-4 py-2">
      <div class="flex items-center gap-2">
        <h1 class="text-[1.15rem] font-bold tracking-tight flex items-center gap-1.5 text-white m-0">
          <span class="w-[7px] h-[7px] bg-bc-orange rounded-full inline-block flex-shrink-0 live-dot-fresh" id="liveDot"></span>
          Iran War Update
          <span class="text-[0.7rem] font-normal text-white/50 ml-1" id="headerFreshness"></span>
        </h1>
        <span class="text-[0.7rem] font-normal text-white/50 block mt-0.5">🇮🇱 Israel Time (IDT)</span>
      </div>
      <a href="/archive" class="btn btn-ghost btn-sm text-white/60 hover:text-white text-[0.75rem] font-medium gap-1 bg-white/8 hover:bg-white/14 rounded-md normal-case">📅 Daily Briefing</a>
    </div>
    <div class="h-[3px] bg-gradient-to-r from-bc-orange to-bc-gold"></div>
  </div>
</div>
