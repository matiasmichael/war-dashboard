---
interface Props {
  article: {
    title: string;
    link: string;
    snippet: string;
    date: string;
    source: string;
    logo: string;
    color: string;
    publisherLogo: string;
    noDate?: boolean;
  };
  idx: number;
  isTopStory: boolean;
}

const { article: a, idx, isTopStory } = Astro.props;

const SNIPPET_LENGTH = 120;

function escapeHtml(str: string): string {
  if (!str) return '';
  return str
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function truncateSnippet(text: string, len: number): string {
  if (!text || text.length <= len) return text || '';
  return text.slice(0, len).replace(/\s+\S*$/, '') + '…';
}

function timeAgo(dateStr: string): string {
  const now = new Date();
  const date = new Date(dateStr);
  const diffMs = now.getTime() - date.getTime();
  const diffMins = Math.floor(diffMs / 60000);
  const diffHours = Math.floor(diffMs / 3600000);
  const diffDays = Math.floor(diffMs / 86400000);
  if (diffMins < 1) return 'just now';
  if (diffMins < 60) return `${diffMins}m ago`;
  if (diffHours < 24) return `${diffHours}h ago`;
  if (diffDays < 7) return `${diffDays}d ago`;
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

const ago = timeAgo(a.date);
const shortSnippet = escapeHtml(truncateSnippet(a.snippet, SNIPPET_LENGTH));
const fullSnippet = escapeHtml(a.snippet);
const hasMore = a.snippet && a.snippet.length > SNIPPET_LENGTH;
const noDateFlag = a.noDate ? 'true' : undefined;
---

<div
  class="card card-bordered bg-white shadow-sm hover:shadow-md transition-all duration-200 mb-2 cursor-pointer active:scale-[0.985]"
  data-source={a.source}
  data-date={a.date}
  data-idx={String(idx)}
  data-no-date={noDateFlag}
>
  <div class="card-body p-3 sm:p-4">
    <div class="flex gap-3 items-start">
      <!-- Publisher Avatar -->
      <div class="avatar flex-shrink-0">
        <div class="w-10 h-10 rounded-full bg-base-200 border border-base-300">
          <img src={a.publisherLogo} alt={a.source} class="w-10 h-10 object-cover rounded-full" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
          <span class="w-10 h-10 rounded-full items-center justify-center text-lg text-white hidden" style={`background:${a.color}`}>{a.logo}</span>
        </div>
      </div>

      <!-- Card Content -->
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-1.5 text-[0.8rem] mb-1">
          <span class="font-semibold" style={`color: ${a.color}`}>{a.source}</span>
          <span class="text-text-muted text-[0.7rem]">·</span>
          <span class="text-text-muted font-normal time-ago" data-date={a.date}>{ago}</span>
          {isTopStory && <span class="badge badge-warning badge-xs text-[0.65rem] font-bold uppercase ml-1">⚡ Top Story</span>}
        </div>
        <h3 class="text-[0.95rem] font-semibold leading-snug text-base-content tracking-tight line-clamp-3 card-title-text">{a.title}</h3>
        {a.snippet && (
          <>
            <p class="text-[0.85rem] text-text-secondary leading-relaxed mt-1 card-snippet-short" set:html={shortSnippet} />
            {hasMore && <p class="text-[0.85rem] text-text-secondary leading-relaxed mt-1 card-snippet-full hidden" set:html={fullSnippet} />}
          </>
        )}
        <div class="card-actions justify-start mt-2 gap-0">
          {hasMore && <button class="btn btn-ghost btn-xs text-primary font-medium expand-btn">Read more</button>}
          <a href={a.link} target="_blank" rel="noopener" class="btn btn-ghost btn-xs text-text-muted font-medium source-link hidden">
            Open article ↗
          </a>
          <button class="btn btn-ghost btn-xs btn-square ml-auto share-btn" data-title={a.title} data-url={a.link} title="Share">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
