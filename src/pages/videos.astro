---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

// Read videos data at build time
import fs from 'node:fs';
import path from 'node:path';

const videosPath = path.join(process.cwd(), 'data', 'videos.json');
let videos: any[] = [];

if (fs.existsSync(videosPath)) {
  try {
    videos = JSON.parse(fs.readFileSync(videosPath, 'utf-8'));
  } catch (e) {
    console.warn('Could not parse videos.json:', e);
  }
}

// Group by channel for filter buttons
const channels = [...new Set(videos.map((v: any) => v.channel))];
const generatedAt = new Date().toISOString();
---

<Base title="Videos — Middle East Pulse" description="Key speeches and updates from major leaders — Israeli PM, IDF, White House, and more." generatedAt={generatedAt}>

  <!-- Header -->
  <div class="navbar bg-header-brown sticky top-0 z-50 px-0">
    <div class="max-w-[720px] mx-auto w-full flex flex-col">
      <div class="relative flex items-center justify-center px-4 py-2">
        <div class="flex flex-col items-center">
          <h1 class="text-[1.15rem] font-bold tracking-tight flex items-center gap-1.5 text-white m-0 whitespace-nowrap">
            <a href="/" class="text-white hover:text-white/80 transition-colors no-underline">Middle East Pulse</a>
          </h1>
          <span class="text-[0.7rem] font-normal text-white/50">🎬 Video Feed</span>
        </div>
        <a href="/" class="btn btn-sm btn-ghost text-white/70 hover:text-white bg-white/8 hover:bg-white/15 rounded-lg absolute right-4 min-h-[36px] px-3 text-[0.78rem]">← Live Feed</a>
      </div>
      <div class="h-[3px] bg-gradient-to-r from-bc-orange to-bc-gold"></div>
    </div>
  </div>

  <div class="max-w-[720px] mx-auto px-3 sm:px-4 pb-12 pt-4">

    <!-- Page Title -->
    <div class="mb-4">
      <h2 class="text-lg font-black tracking-tight text-base-content flex items-center gap-2">
        🎬 Video Feed
      </h2>
      <p class="text-[0.78rem] text-text-muted mt-0.5">Key speeches and updates from major leaders — refreshed every 3 minutes.</p>
    </div>

    <!-- Channel Filter -->
    {channels.length > 0 && (
      <div class="flex gap-2 flex-wrap mb-4">
        <button class="filter-btn btn btn-xs rounded-full btn-primary text-[0.72rem] font-medium" data-channel="all">All</button>
        {channels.map((ch: string) => {
          const chVideo = videos.find((v: any) => v.channel === ch);
          const emoji = chVideo?.channelEmoji || '📺';
          return (
            <button class="filter-btn btn btn-xs rounded-full btn-ghost border border-base-300 text-text-muted text-[0.72rem] font-medium" data-channel={ch}>
              {emoji} {ch}
            </button>
          );
        })}
      </div>
    )}

    <!-- Video Grid -->
    {videos.length === 0 ? (
      <div class="text-center py-16 text-text-muted">
        <div class="text-5xl mb-4 opacity-50">🎬</div>
        <h3 class="text-lg font-bold text-base-content mb-2">No videos yet</h3>
        <p class="text-sm max-w-[400px] mx-auto">Videos from key channels will appear here once the first fetch runs.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3" id="videoGrid">
        {videos.map((video: any) => (
          <a
            href={video.link}
            target="_blank"
            rel="noopener noreferrer"
            class="video-card card card-bordered bg-white shadow-sm hover:shadow-md transition-all duration-200 overflow-hidden group"
            data-channel={video.channel}
            data-date={video.published}
          >
            <!-- Thumbnail -->
            <figure class="relative aspect-video overflow-hidden bg-base-200">
              <img
                src={video.thumbnail}
                alt={video.title}
                class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-300"
                loading="lazy"
              />
              <!-- Play overlay -->
              <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                <div class="w-12 h-12 bg-black/70 rounded-full flex items-center justify-center">
                  <svg class="w-5 h-5 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
              </div>
              <!-- Channel badge -->
              <div class="absolute top-2 left-2">
                <span class="badge badge-sm text-white text-[0.62rem] font-bold shadow-md border-0" style={`background-color: ${video.channelColor}CC;`}>
                  {video.channelEmoji} {video.channel}
                </span>
              </div>
            </figure>

            <div class="card-body p-3 gap-1">
              <h3 class="text-[0.82rem] font-bold leading-snug tracking-tight text-base-content line-clamp-2 m-0">
                {video.title}
              </h3>
              {video.description && video.description !== video.channel && (
                <p class="text-[0.7rem] text-text-muted leading-relaxed line-clamp-2 m-0">
                  {video.description}
                </p>
              )}
              <div class="flex items-center justify-between mt-1">
                <span class="time-ago text-[0.68rem] text-text-muted font-medium" data-date={video.published}></span>
                <span class="text-[0.68rem] text-primary font-semibold opacity-0 group-hover:opacity-100 transition-opacity">Watch →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}

  </div>

  <Footer />

  <script>
    // ===== TIMESTAMP COMPUTATION =====
    function computeTimeAgo(dateStr: string): string {
      const now = new Date();
      const date = new Date(dateStr);
      const rawDiffMs = now.getTime() - date.getTime();
      const diffMs = Math.max(0, rawDiffMs);
      const diffMins = Math.floor(diffMs / 60000);
      const diffHours = Math.floor(diffMs / 3600000);
      const diffDays = Math.floor(diffMs / 86400000);
      if (diffMins < 1) return 'just now';
      if (diffMins < 60) return diffMins + 'm ago';
      if (diffHours < 24) return diffHours + 'h ago';
      if (diffDays < 7) return diffDays + 'd ago';
      return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
    }

    function refreshAllTimestamps(): void {
      document.querySelectorAll('.time-ago[data-date]').forEach(function(el) {
        const dateAttr = el.getAttribute('data-date');
        if (dateAttr) el.textContent = computeTimeAgo(dateAttr);
      });
    }

    refreshAllTimestamps();
    setInterval(refreshAllTimestamps, 30000);

    // ===== CHANNEL FILTERS =====
    let activeFilter = 'all';

    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        // Remove active from all
        document.querySelectorAll('.filter-btn').forEach(b => {
          b.classList.remove('btn-primary');
          b.classList.add('btn-ghost', 'border', 'border-base-300', 'text-text-muted');
        });
        // Set active
        btn.classList.add('btn-primary');
        btn.classList.remove('btn-ghost', 'border', 'border-base-300', 'text-text-muted');

        activeFilter = (btn as HTMLElement).dataset.channel || 'all';

        document.querySelectorAll('.video-card').forEach(card => {
          const el = card as HTMLElement;
          const match = activeFilter === 'all' || el.dataset.channel === activeFilter;
          el.style.display = match ? '' : 'none';
        });
      });
    });
  </script>

  <style>
    .line-clamp-2 {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  </style>
</Base>
