---
import Base from '../../layouts/Base.astro';
import '../../styles/global.css';
import { t, localizedPath } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';

const lang: Lang = 'he';

// Feed metadata for the sources grid
import feedsData from '../../feeds.json';

// Build favicon URLs
function getFaviconUrl(domain: string) {
  return `https://www.google.com/s2/favicons?domain=${domain}&sz=128`;
}

// Active sources
const activeSources = feedsData.filter((f: any) => f.name !== 'Haaretz' && f.name !== 'CNN');
---

<Base
  title={t(lang, 'about.title')}
  description={t(lang, 'about.description')}
  lang={lang}
>
  <!-- Header -->
  <div class="navbar bg-header-brown sticky top-0 z-50 px-0">
    <div class="max-w-[680px] mx-auto w-full flex flex-col">
      <div class="relative flex items-center justify-center px-4 py-2">
        <div class="flex flex-col items-center">
          <h1 class="text-[1.15rem] font-bold tracking-tight flex items-center gap-1.5 text-white m-0 whitespace-nowrap">
            <a href={localizedPath(lang, '/')} class="text-white hover:text-white/80 transition-colors no-underline">{t(lang, 'site.title')}</a>
          </h1>
          <span class="text-[0.7rem] font-normal text-white/50">{t(lang, 'about.subtitle')}</span>
        </div>
        <a href={localizedPath(lang, '/')} class="btn btn-sm btn-ghost text-white/70 hover:text-white bg-white/8 hover:bg-white/15 rounded-lg absolute min-h-[36px] px-3 text-[0.78rem]" style={lang === 'he' ? 'left: 1rem' : 'right: 1rem'}>{t(lang, 'nav.liveFeed')}</a>
      </div>
      <div class="h-[3px] bg-gradient-to-r from-bc-orange to-bc-gold"></div>
    </div>
  </div>

  <div class="max-w-[680px] mx-auto px-4 pb-16 pt-6">

    <!-- Hero -->
    <div class="mb-8 text-center">
      <div class="text-4xl mb-3">🔶</div>
      <h2 class="text-2xl font-black tracking-tight text-base-content mb-2">{t(lang, 'site.title')}</h2>
      <p class="text-text-muted text-[0.88rem] leading-relaxed max-w-[420px] mx-auto">
        {t(lang, 'about.heroDesc')}
      </p>
    </div>

    <!-- What is it -->
    <div class="card card-bordered bg-white shadow-sm mb-4">
      <div class="card-body px-5 py-4 gap-3">
        <h3 class="text-[0.78rem] font-bold uppercase tracking-wider text-primary m-0">{t(lang, 'about.whatIsIt')}</h3>
        <p class="text-[0.88rem] leading-relaxed text-text-secondary m-0">
          {t(lang, 'about.whatIsItP1')}
        </p>
        <p class="text-[0.88rem] leading-relaxed text-text-secondary m-0">
          {t(lang, 'about.whatIsItP2')}
        </p>
      </div>
    </div>

    <!-- How it works -->
    <div class="card card-bordered bg-white shadow-sm mb-4">
      <div class="card-body px-5 py-4 gap-4">
        <h3 class="text-[0.78rem] font-bold uppercase tracking-wider text-primary m-0">{t(lang, 'about.howItWorks')}</h3>

        <div class="flex gap-3 items-start">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-[0.9rem]">1</div>
          <div>
            <p class="text-[0.88rem] font-semibold text-base-content m-0 mb-0.5">{t(lang, 'about.step1Title')}</p>
            <p class="text-[0.82rem] text-text-secondary leading-relaxed m-0">
              {t(lang, 'about.step1Desc')}
            </p>
          </div>
        </div>

        <div class="flex gap-3 items-start">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-[0.9rem]">2</div>
          <div>
            <p class="text-[0.88rem] font-semibold text-base-content m-0 mb-0.5">{t(lang, 'about.step2Title')}</p>
            <p class="text-[0.82rem] text-text-secondary leading-relaxed m-0">
              {t(lang, 'about.step2Desc')}
            </p>
          </div>
        </div>

        <div class="flex gap-3 items-start">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-[0.9rem]">3</div>
          <div>
            <p class="text-[0.88rem] font-semibold text-base-content m-0 mb-0.5">{t(lang, 'about.step3Title')}</p>
            <p class="text-[0.82rem] text-text-secondary leading-relaxed m-0">
              {t(lang, 'about.step3Desc')}
            </p>
          </div>
        </div>

        <div class="flex gap-3 items-start">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-[0.9rem]">4</div>
          <div>
            <p class="text-[0.88rem] font-semibold text-base-content m-0 mb-0.5">{t(lang, 'about.step4Title')}</p>
            <p class="text-[0.82rem] text-text-secondary leading-relaxed m-0">
              {t(lang, 'about.step4Desc')}
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Sources -->
    <div class="card card-bordered bg-white shadow-sm mb-4">
      <div class="card-body px-5 py-4 gap-4">
        <div class="flex items-center justify-between">
          <h3 class="text-[0.78rem] font-bold uppercase tracking-wider text-primary m-0">{t(lang, 'about.sources')}</h3>
          <span class="text-[0.72rem] text-text-muted">{activeSources.length} {t(lang, 'about.activeFeeds')}</span>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          {activeSources.map((feed: any) => (
            <div class="flex flex-col items-center gap-1.5 p-3 rounded-xl bg-base-100 border border-base-200 hover:border-base-300 transition-colors">
              <img
                src={getFaviconUrl(feed.faviconDomain)}
                alt={feed.name}
                width="32"
                height="32"
                class="rounded-md w-8 h-8 object-contain"
                onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
              />
              <span
                class="text-xl hidden items-center justify-center"
                style="display:none"
              >📰</span>
              <span class="text-[0.72rem] font-semibold text-base-content text-center leading-tight">{feed.shortName}</span>
            </div>
          ))}
        </div>

        <p class="text-[0.78rem] text-text-muted leading-relaxed m-0">
          {t(lang, 'about.sourcesDesc')}
        </p>
      </div>
    </div>

    <!-- Update frequency -->
    <div class="card card-bordered bg-white shadow-sm mb-4">
      <div class="card-body px-5 py-4 gap-3">
        <h3 class="text-[0.78rem] font-bold uppercase tracking-wider text-primary m-0">{t(lang, 'about.updateSchedule')}</h3>
        <div class="space-y-2.5">
          <div class="flex items-center gap-3">
            <span class="text-lg w-6 text-center flex-shrink-0">📰</span>
            <div>
              <span class="text-[0.84rem] font-semibold text-base-content">{t(lang, 'about.articlesSchedule')}</span>
              <span class="text-[0.82rem] text-text-muted ms-1.5">{t(lang, 'about.articlesFreq')}</span>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-lg w-6 text-center flex-shrink-0">🔍</span>
            <div>
              <span class="text-[0.84rem] font-semibold text-base-content">{t(lang, 'about.keyDevSchedule')}</span>
              <span class="text-[0.82rem] text-text-muted ms-1.5">{t(lang, 'about.keyDevFreq')}</span>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-lg w-6 text-center flex-shrink-0">🧠</span>
            <div>
              <span class="text-[0.84rem] font-semibold text-base-content">{t(lang, 'about.sitrepSchedule')}</span>
              <span class="text-[0.82rem] text-text-muted ms-1.5">{t(lang, 'about.sitrepFreq')}</span>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-lg w-6 text-center flex-shrink-0">📅</span>
            <div>
              <span class="text-[0.84rem] font-semibold text-base-content">{t(lang, 'about.dailyBriefingSchedule')}</span>
              <span class="text-[0.82rem] text-text-muted ms-1.5">{t(lang, 'about.dailyBriefingFreq')}</span>
            </div>
          </div>
        </div>
        <p class="text-[0.78rem] text-text-muted m-0">
          {t(lang, 'about.liveIndicatorNote')}
        </p>
      </div>
    </div>

    <!-- AI Disclaimer -->
    <div class="card card-bordered border-warning/40 bg-warning/5 shadow-sm mb-4">
      <div class="card-body px-5 py-4 gap-3">
        <h3 class="text-[0.78rem] font-bold uppercase tracking-wider text-warning-content m-0 flex items-center gap-1.5">
          <span>{t(lang, 'about.aiDisclaimer')}</span>
        </h3>
        <p class="text-[0.85rem] leading-relaxed text-text-secondary m-0">
          {t(lang, 'about.aiDisclaimerP1')}
        </p>
        <p class="text-[0.85rem] leading-relaxed text-text-secondary m-0">
          {t(lang, 'about.aiDisclaimerP2')}
        </p>
        <p class="text-[0.85rem] leading-relaxed text-text-secondary m-0">
          {t(lang, 'about.aiDisclaimerP3')}
        </p>
      </div>
    </div>

    <!-- Archive link -->
    <div class="card card-bordered bg-white shadow-sm mb-4">
      <div class="card-body px-5 py-4 gap-2">
        <h3 class="text-[0.78rem] font-bold uppercase tracking-wider text-primary m-0">{t(lang, 'about.archiveSection')}</h3>
        <p class="text-[0.85rem] leading-relaxed text-text-secondary m-0">
          {t(lang, 'about.archiveSectionDesc')}
        </p>
        <a href={localizedPath(lang, '/archive')} class="btn btn-outline btn-primary btn-sm mt-1 w-fit text-[0.82rem]">
          {t(lang, 'about.viewArchive')}
        </a>
      </div>
    </div>

    <!-- Back to dashboard -->
    <div class="text-center pt-2">
      <a href={localizedPath(lang, '/')} class="btn btn-primary gap-2 text-[0.88rem]">
        {t(lang, 'nav.backToLive')}
      </a>
    </div>

  </div>

  <!-- Footer -->
  <footer class="text-center py-8 text-text-muted text-[0.72rem] border-t border-base-300 bg-white">
    <p>{t(lang, 'footer.line1')}</p>
    <p class="mt-1 opacity-70">{t(lang, 'footer.line2')}</p>
  </footer>
</Base>
