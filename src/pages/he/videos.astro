---
import Base from '../../layouts/Base.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';
import { t, localizedPath } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';

const lang: Lang = 'he';

// Read videos data at build time
import fs from 'node:fs';
import path from 'node:path';

const videosPath = path.join(process.cwd(), 'data', 'videos.json');
let videos: any[] = [];

if (fs.existsSync(videosPath)) {
  try {
    videos = JSON.parse(fs.readFileSync(videosPath, 'utf-8'));
  } catch (e) {
    console.warn('Could not parse videos.json:', e);
  }
}

// Group by channel for filter buttons
const channels = [...new Set(videos.map((v: any) => v.channel))];
const generatedAt = new Date().toISOString();

function getFaviconUrl(domain: string): string {
  return `https://www.google.com/s2/favicons?domain=${domain}&sz=128`;
}
---

<Base title={t(lang, 'videos.title')} description={t(lang, 'videos.description')} generatedAt={generatedAt} lang={lang}>

  <!-- Header -->
  <div class="navbar bg-header-brown sticky top-0 z-50 px-0">
    <div class="max-w-[720px] mx-auto w-full flex flex-col">
      <div class="relative flex items-center justify-center px-4 py-2">
        <div class="flex flex-col items-center">
          <h1 class="text-[1.15rem] font-bold tracking-tight flex items-center gap-1.5 text-white m-0 whitespace-nowrap">
            <a href={localizedPath(lang, '/')} class="text-white hover:text-white/80 transition-colors no-underline">{t(lang, 'site.title')}</a>
          </h1>
          <span class="text-[0.7rem] font-normal text-white/50">{t(lang, 'videos.subtitle')}</span>
        </div>
        <a href={localizedPath(lang, '/')} class="btn btn-sm btn-ghost text-white/70 hover:text-white bg-white/8 hover:bg-white/15 rounded-lg absolute min-h-[36px] px-3 text-[0.78rem]" style={lang === 'he' ? 'left: 1rem' : 'right: 1rem'}>{t(lang, 'nav.liveFeed')}</a>
      </div>
      <div class="h-[3px] bg-gradient-to-r from-bc-orange to-bc-gold"></div>
    </div>
  </div>

  <div class="max-w-[720px] mx-auto px-3 sm:px-4 pb-12 pt-4">

    <!-- Page Title -->
    <div class="mb-4">
      <h2 class="text-lg font-black tracking-tight text-base-content flex items-center gap-2">
        {t(lang, 'videos.heading')}
      </h2>
      <p class="text-[0.78rem] text-text-muted mt-0.5">{t(lang, 'videos.refreshNote')}</p>
    </div>

    <!-- Channel Filter -->
    {channels.length > 0 && (
      <div class="flex gap-2 flex-wrap mb-4">
        <button class="filter-btn btn btn-xs rounded-full btn-primary text-[0.72rem] font-medium" data-channel="all">{t(lang, 'videos.all')}</button>
        {channels.map((ch: string) => {
          const chVideo = videos.find((v: any) => v.channel === ch);
          const faviconDomain = chVideo?.channelFaviconDomain;
          return (
            <button class="filter-btn btn btn-xs rounded-full btn-ghost border border-base-300 text-text-muted text-[0.72rem] font-medium flex items-center gap-1" data-channel={ch}>
              {faviconDomain && <img src={getFaviconUrl(faviconDomain)} class="w-4 h-4 rounded-sm" alt="" />}
              {ch}
            </button>
          );
        })}
      </div>
    )}

    <!-- Video Grid -->
    {videos.length === 0 ? (
      <div class="text-center py-16 text-text-muted">
        <div class="text-5xl mb-4 opacity-50">🎬</div>
        <h3 class="text-lg font-bold text-base-content mb-2">{t(lang, 'videos.noVideos')}</h3>
        <p class="text-sm max-w-[400px] mx-auto">{t(lang, 'videos.noVideosDesc')}</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3" id="videoGrid">
        {videos.map((video: any) => (
          <div
            class="video-card card card-bordered bg-white shadow-sm hover:shadow-md transition-all duration-200 overflow-hidden group cursor-pointer"
            data-channel={video.channel}
            data-date={video.published}
            data-video-id={video.videoId}
            data-title={video.title}
            role="button"
            tabindex="0"
          >
            <!-- Thumbnail -->
            <figure class="relative aspect-video overflow-hidden bg-base-200">
              <img
                src={video.thumbnail}
                alt={video.title}
                class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-300"
                loading="lazy"
              />
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-14 h-14 bg-black/50 group-hover:bg-black/75 rounded-full flex items-center justify-center transition-colors duration-200 shadow-lg">
                  <svg class="w-6 h-6 text-white ms-1" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
              </div>
              <div class="absolute top-2" style={lang === 'he' ? 'right: 0.5rem' : 'left: 0.5rem'}>
                <span class="badge badge-sm text-white text-[0.62rem] font-bold shadow-md border-0 flex items-center gap-1" style={`background-color: ${video.channelColor}CC;`}>
                  {video.channelFaviconDomain && <img src={getFaviconUrl(video.channelFaviconDomain)} class="w-3 h-3 rounded-sm" alt="" />}
                  {video.channel}
                </span>
              </div>
            </figure>

            <div class="card-body p-3 gap-1">
              <h3 class="text-[0.82rem] font-bold leading-snug tracking-tight text-base-content line-clamp-2 m-0">
                {video.title}
              </h3>
              {video.description && video.description !== video.channel && (
                <p class="text-[0.7rem] text-text-muted leading-relaxed line-clamp-2 m-0">
                  {video.description}
                </p>
              )}
              <div class="flex items-center justify-between mt-1">
                <span class="time-ago text-[0.68rem] text-text-muted font-medium" data-date={video.published}></span>
                <span class="text-[0.68rem] text-primary font-semibold opacity-0 group-hover:opacity-100 transition-opacity">{t(lang, 'videos.play')}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    )}

  </div>

  <Footer lang={lang} />

  <!-- ===== VIDEO MODAL ===== -->
  <dialog id="videoModal" class="video-modal">
    <div class="video-modal-backdrop" id="videoModalBackdrop"></div>
    <div class="video-modal-content">
      <button class="video-modal-close" id="videoModalClose" aria-label={t(lang, 'videos.closeVideo')}>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
      <p class="video-modal-title" id="videoModalTitle"></p>
      <div class="video-modal-frame-wrap">
        <iframe
          id="videoModalFrame"
          src=""
          frameborder="0"
          allowfullscreen
          allow="autoplay; fullscreen; encrypted-media; picture-in-picture"
        ></iframe>
      </div>
    </div>
  </dialog>

  <script>
    // ===== TIMESTAMP COMPUTATION =====
    function computeTimeAgo(dateStr: string): string {
      const now = new Date();
      const date = new Date(dateStr);
      const rawDiffMs = now.getTime() - date.getTime();
      const diffMs = Math.max(0, rawDiffMs);
      const diffMins = Math.floor(diffMs / 60000);
      const diffHours = Math.floor(diffMs / 3600000);
      const diffDays = Math.floor(diffMs / 86400000);
      if (diffMins < 1) return 'just now';
      if (diffMins < 60) return diffMins + 'm ago';
      if (diffHours < 24) return diffHours + 'h ago';
      if (diffDays < 7) return diffDays + 'd ago';
      return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
    }

    function refreshAllTimestamps(): void {
      document.querySelectorAll('.time-ago[data-date]').forEach(function(el) {
        const dateAttr = el.getAttribute('data-date');
        if (dateAttr) el.textContent = computeTimeAgo(dateAttr);
      });
    }

    refreshAllTimestamps();
    setInterval(refreshAllTimestamps, 30000);

    // ===== CHANNEL FILTERS =====
    let activeFilter = 'all';

    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.filter-btn').forEach(b => {
          b.classList.remove('btn-primary');
          b.classList.add('btn-ghost', 'border', 'border-base-300', 'text-text-muted');
        });
        btn.classList.add('btn-primary');
        btn.classList.remove('btn-ghost', 'border', 'border-base-300', 'text-text-muted');

        activeFilter = (btn as HTMLElement).dataset.channel || 'all';

        document.querySelectorAll('.video-card').forEach(card => {
          const el = card as HTMLElement;
          const match = activeFilter === 'all' || el.dataset.channel === activeFilter;
          el.style.display = match ? '' : 'none';
        });
      });
    });

    // ===== INLINE VIDEO MODAL =====
    const modal = document.getElementById('videoModal') as HTMLDialogElement | null;
    const backdrop = document.getElementById('videoModalBackdrop');
    const closeBtn = document.getElementById('videoModalClose');
    const frame = document.getElementById('videoModalFrame') as HTMLIFrameElement | null;
    const titleEl = document.getElementById('videoModalTitle');

    function openModal(videoId: string, title: string): void {
      if (!modal || !frame || !titleEl) return;
      frame.src = `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0`;
      titleEl.textContent = title;
      modal.showModal();
      document.body.style.overflow = 'hidden';
    }

    function closeModal(): void {
      if (!modal || !frame) return;
      frame.src = '';
      modal.close();
      document.body.style.overflow = '';
    }

    document.querySelectorAll('.video-card').forEach(card => {
      const el = card as HTMLElement;

      const handleOpen = () => {
        const videoId = el.dataset.videoId;
        const title = el.dataset.title || '';
        if (videoId) openModal(videoId, title);
      };

      el.addEventListener('click', handleOpen);
      el.addEventListener('keydown', (e: Event) => {
        const ke = e as KeyboardEvent;
        if (ke.key === 'Enter' || ke.key === ' ') {
          ke.preventDefault();
          handleOpen();
        }
      });
    });

    closeBtn?.addEventListener('click', closeModal);
    backdrop?.addEventListener('click', closeModal);

    modal?.addEventListener('cancel', (e: Event) => {
      e.preventDefault();
      closeModal();
    });
  </script>

  <style>
    .line-clamp-2 {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .video-modal {
      position: fixed;
      inset: 0;
      width: 100%;
      height: 100%;
      max-width: 100%;
      max-height: 100%;
      background: transparent;
      border: none;
      padding: 0;
      margin: 0;
      z-index: 9999;
      display: none;
    }

    .video-modal[open] {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .video-modal-backdrop {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.82);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      cursor: pointer;
      z-index: 0;
    }

    .video-modal-content {
      position: relative;
      z-index: 1;
      width: min(92vw, 860px);
      background: #111;
      border-radius: 16px;
      overflow: hidden;
      box-shadow:
        0 0 0 1px rgba(255,255,255,0.08),
        0 32px 80px rgba(0, 0, 0, 0.7),
        0 8px 24px rgba(0, 0, 0, 0.5);
      animation: modalIn 0.22s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    @keyframes modalIn {
      from { opacity: 0; transform: scale(0.92) translateY(12px); }
      to   { opacity: 1; transform: scale(1)    translateY(0); }
    }

    .video-modal-close {
      position: absolute;
      top: 12px;
      z-index: 10;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.18);
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: background 0.15s, transform 0.15s;
    }

    [dir="ltr"] .video-modal-close { right: 12px; }
    [dir="rtl"] .video-modal-close { left: 12px; }

    .video-modal-close:hover {
      background: rgba(255,255,255,0.24);
      transform: scale(1.08);
    }

    .video-modal-title {
      font-size: 0.8rem;
      font-weight: 600;
      color: rgba(255,255,255,0.75);
      padding: 14px 52px 10px 16px;
      margin: 0;
      line-height: 1.35;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .video-modal-frame-wrap {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 9;
      background: #000;
    }

    .video-modal-frame-wrap iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: none;
      display: block;
    }

    .video-modal::backdrop {
      display: none;
    }
  </style>
</Base>
