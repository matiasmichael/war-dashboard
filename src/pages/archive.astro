---
// Archive page — Daily Briefing
// Uses Base layout for shared head/boilerplate
import Base from '../layouts/Base.astro';
import '../styles/global.css';
---

<Base title="Daily Briefing — Middle East Pulse" description="Historical daily intelligence briefings from the Middle East conflict">

  <!-- Header -->
  <div class="navbar bg-white/92 backdrop-blur-xl border-b border-base-300 sticky top-0 z-50 px-4 sm:px-6 py-3">
    <div class="max-w-[720px] mx-auto w-full flex items-center justify-between">
      <h1 class="text-xl font-bold tracking-tight flex items-center gap-2">📅 Daily Briefing</h1>
      <a href="/" class="btn btn-ghost btn-sm text-primary font-semibold text-[0.82rem] gap-1">← Live Feed</a>
    </div>
  </div>

  <!-- Date Picker -->
  <div class="max-w-[720px] mx-auto px-4 sm:px-6 py-3 flex items-center gap-2 overflow-x-auto scrollbar-none" id="datePicker"></div>

  <!-- Day Navigation -->
  <div class="max-w-[720px] mx-auto px-4 sm:px-6 flex justify-between items-center mb-2" id="dayNav">
    <button class="btn btn-outline btn-sm min-h-[44px] min-w-[44px] text-primary font-semibold text-sm" id="prevDay">← Previous</button>
    <span class="text-sm font-semibold text-base-content" id="currentDateLabel"></span>
    <button class="btn btn-outline btn-sm min-h-[44px] min-w-[44px] text-primary font-semibold text-sm" id="nextDay">Next →</button>
  </div>

  <!-- Content Container -->
  <div class="max-w-[720px] mx-auto px-4 sm:px-6 pb-12" id="briefingContainer">
    <div class="text-center py-12 text-text-muted text-sm">
      <div class="w-6 h-6 border-3 border-base-300 border-t-primary rounded-full animate-spin mx-auto mb-4"></div>
      Loading briefing...
    </div>
  </div>

  <!-- noscript fallback -->
  <noscript>
    <div class="max-w-[720px] mx-auto px-4 sm:px-6 py-16 text-center text-base-content">
      <div class="text-5xl mb-4 opacity-50">⚠️</div>
      <h2 class="text-lg font-bold mb-2">JavaScript Required</h2>
      <p class="text-sm text-text-muted max-w-[400px] mx-auto">This page requires JavaScript to load daily briefings. Please enable JavaScript in your browser settings.</p>
    </div>
  </noscript>

  <script>
    // ===== STATE =====
    let availableDates: string[] = [];
    let currentDate: string | null = null;
    const ISRAEL_TZ = 'Asia/Jerusalem';

    // ===== INIT =====
    async function init() {
      try {
        const res = await fetch('/api/archive/dates');
        if (res.ok) {
          availableDates = await res.json();
        }
      } catch (e) {
        console.warn('Could not fetch dates from API, trying static manifest');
      }

      if (availableDates.length === 0) {
        try {
          const res = await fetch('/data/daily/manifest.json');
          if (res.ok) {
            availableDates = await res.json();
          }
        } catch (e) {
          console.warn('No manifest found');
        }
      }

      if (availableDates.length === 0) {
        const container = document.getElementById('briefingContainer');
        if (container) {
          container.innerHTML = `
            <div class="text-center py-16 text-text-muted">
              <div class="text-5xl mb-4 opacity-50">📭</div>
              <h2 class="text-lg font-bold text-base-content mb-2">No briefings yet</h2>
              <p class="text-sm max-w-[400px] mx-auto">Daily intelligence summaries will appear here once the first daily summary is generated. Check back tomorrow.</p>
            </div>
          `;
        }
        return;
      }

      availableDates.sort((a, b) => b.localeCompare(a));

      const hashDate = window.location.hash.replace('#', '');
      if (hashDate && availableDates.includes(hashDate)) {
        currentDate = hashDate;
      } else {
        currentDate = availableDates[0];
      }

      renderDatePicker();
      if (currentDate) loadBriefing(currentDate);
    }

    function renderDatePicker() {
      const picker = document.getElementById('datePicker');
      if (!picker) return;
      picker.innerHTML = availableDates.map(d => {
        const date = new Date(d + 'T12:00:00');
        const label = date.toLocaleDateString('en-US', { timeZone: ISRAEL_TZ, month: 'short', day: 'numeric' });
        const isActive = d === currentDate;
        return `<a class="btn btn-sm rounded-full whitespace-nowrap flex-shrink-0 text-[0.78rem] font-medium ${isActive ? 'btn-primary' : 'btn-outline btn-neutral text-text-muted'}" href="#${d}" data-date="${d}">${label}</a>`;
      }).join('');

      picker.querySelectorAll('[data-date]').forEach(pill => {
        pill.addEventListener('click', (e) => {
          e.preventDefault();
          const dateStr = (pill as HTMLElement).dataset.date;
          if (dateStr) loadBriefing(dateStr);
        });
      });
    }

    function navigateDay(delta: number) {
      if (!currentDate) return;
      const idx = availableDates.indexOf(currentDate);
      const newIdx = idx - delta;
      if (newIdx >= 0 && newIdx < availableDates.length) {
        loadBriefing(availableDates[newIdx]);
      }
    }

    document.getElementById('prevDay')?.addEventListener('click', () => navigateDay(-1));
    document.getElementById('nextDay')?.addEventListener('click', () => navigateDay(1));

    function updateNavButtons() {
      if (!currentDate) return;
      const idx = availableDates.indexOf(currentDate);
      const prevBtn = document.getElementById('prevDay') as HTMLButtonElement;
      const nextBtn = document.getElementById('nextDay') as HTMLButtonElement;
      if (prevBtn) prevBtn.disabled = idx >= availableDates.length - 1;
      if (nextBtn) nextBtn.disabled = idx <= 0;

      const date = new Date(currentDate + 'T12:00:00');
      const label = document.getElementById('currentDateLabel');
      if (label) {
        label.textContent = date.toLocaleDateString('en-US', {
          timeZone: ISRAEL_TZ, weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
        });
      }
    }

    async function loadBriefing(dateStr: string) {
      currentDate = dateStr;
      window.location.hash = dateStr;

      renderDatePicker();
      updateNavButtons();

      const container = document.getElementById('briefingContainer');
      if (!container) return;
      container.innerHTML = '<div class="text-center py-12 text-text-muted text-sm"><div class="w-6 h-6 border-3 border-base-300 border-t-primary rounded-full animate-spin mx-auto mb-4"></div>Loading briefing...</div>';

      try {
        let data: any;
        let res = await fetch(`/api/archive/${dateStr}`);
        if (res.ok) {
          data = await res.json();
        } else {
          res = await fetch(`/data/daily/${dateStr}.json`);
          if (!res.ok) throw new Error('Briefing not found');
          data = await res.json();
        }

        renderBriefing(data);
      } catch (e) {
        container.innerHTML = `
          <div class="text-center py-16 text-text-muted">
            <div class="text-5xl mb-4 opacity-50">📄</div>
            <h2 class="text-lg font-bold text-base-content mb-2">Briefing not available</h2>
            <p class="text-sm max-w-[400px] mx-auto">The daily summary for ${dateStr} couldn't be loaded. It may not have been generated yet.</p>
          </div>
        `;
      }
    }

    function escHtml(str: string): string {
      if (!str) return '';
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    function getEscalationLabel(level: number) {
      const labels: Record<number, { text: string; emoji: string; cls: string }> = {
        1: { text: 'Calm', emoji: '🟢', cls: 'bg-success/20 text-success' },
        2: { text: 'Tensions', emoji: '🟡', cls: 'bg-warning/20 text-warning-content' },
        3: { text: 'Active Conflict', emoji: '🟠', cls: 'bg-bc-orange/15 text-bc-orange' },
        4: { text: 'Major Escalation', emoji: '🔴', cls: 'bg-error/15 text-error' },
        5: { text: 'Full-Scale War', emoji: '⚫', cls: 'bg-neutral/15 text-neutral' }
      };
      return labels[level] || labels[3];
    }

    function getCategoryTag(category: string): string {
      const cats: Record<string, { emoji: string; label: string; cls: string }> = {
        diplomacy: { emoji: '🤝', label: 'Diplomacy', cls: 'badge-info' },
        military: { emoji: '💥', label: 'Military', cls: 'badge-error' },
        intelligence: { emoji: '🕵️', label: 'Intelligence', cls: 'badge-warning' },
        proxy: { emoji: '🌍', label: 'Proxy', cls: 'badge-secondary' }
      };
      const cat = cats[(category || '').toLowerCase()];
      if (!cat) return '';
      return `<span class="badge badge-xs ${cat.cls} ml-1.5">${cat.emoji} ${cat.label}</span>`;
    }

    function getNavDateLabel(dateStr: string): string {
      const d = new Date(dateStr + 'T12:00:00');
      return d.toLocaleDateString('en-US', { month: 'long', day: 'numeric' });
    }

    function renderBriefing(data: any) {
      const container = document.getElementById('briefingContainer');
      if (!container) return;
      const date = new Date(data.date + 'T12:00:00');
      const dateFormatted = date.toLocaleDateString('en-US', {
        timeZone: ISRAEL_TZ, weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
      });

      const stats = data.statistics || {};
      const escLevel = stats.escalation_level || 3;
      const esc = getEscalationLabel(escLevel);

      const idx = currentDate ? availableDates.indexOf(currentDate) : -1;
      const prevDate = idx < availableDates.length - 1 ? availableDates[idx + 1] : null;
      const nextDate = idx > 0 ? availableDates[idx - 1] : null;

      const prevLink = prevDate
        ? `<a class="btn btn-outline btn-sm min-h-[44px] min-w-[44px] text-primary font-semibold text-sm" href="#${prevDate}" data-nav-date="${prevDate}">← ${getNavDateLabel(prevDate)}</a>`
        : `<span class="btn btn-outline btn-sm btn-disabled min-h-[44px] min-w-[44px] text-text-muted text-sm">← Previous</span>`;
      const nextLink = nextDate
        ? `<a class="btn btn-outline btn-sm min-h-[44px] min-w-[44px] text-primary font-semibold text-sm" href="#${nextDate}" data-nav-date="${nextDate}">${getNavDateLabel(nextDate)} →</a>`
        : `<span class="btn btn-outline btn-sm btn-disabled min-h-[44px] min-w-[44px] text-text-muted text-sm">Next →</span>`;

      // Key events as DaisyUI timeline
      const eventsHTML = (data.key_events || []).map((ev: any, i: number) => {
        const isLast = i === (data.key_events || []).length - 1;
        return `
        <li>
          ${i > 0 ? '<hr class="bg-primary"/>' : ''}
          <div class="timeline-start text-right pr-2">
            <span class="text-[0.75rem] font-bold text-primary">${escHtml(ev.time)}</span>
            <span class="block text-[0.62rem] font-medium text-text-muted">(Israel)</span>
          </div>
          <div class="timeline-middle">
            <div class="w-2.5 h-2.5 bg-primary rounded-full"></div>
          </div>
          <div class="timeline-end timeline-box bg-white border-base-300 cursor-pointer hover:bg-base-200 transition-colors" onclick="this.querySelector('.timeline-desc')?.classList.toggle('hidden')">
            <div class="text-[0.95rem] font-bold text-base-content leading-tight tracking-tight">
              ${escHtml(ev.headline)}${getCategoryTag(ev.category)}
            </div>
            <div class="text-[0.72rem] text-text-muted mt-0.5">${escHtml(ev.source)}</div>
            ${ev.description ? `<div class="timeline-desc hidden text-[0.82rem] text-text-secondary leading-relaxed mt-1.5 pt-1.5 border-t border-base-200">${escHtml(ev.description)}</div>` : ''}
          </div>
          ${!isLast ? '<hr class="bg-primary"/>' : ''}
        </li>`;
      }).join('');

      // What Changed Today
      let whatChangedHTML = '';
      if (data.what_changed && Array.isArray(data.what_changed) && data.what_changed.length > 0) {
        whatChangedHTML = `
          <div class="card card-bordered bg-white shadow-sm mb-2.5">
            <div class="card-body p-5">
              <h3 class="text-[0.78rem] font-bold uppercase tracking-wider text-primary flex items-center gap-1.5 mb-3">⚡ What Changed Today</h3>
              <ul class="space-y-0">
                ${data.what_changed.slice(0, 3).map((item: string) => `<li class="text-sm leading-relaxed text-text-secondary py-1.5 pl-5 relative border-t border-base-200 first:border-t-0"><span class="absolute left-0 text-primary font-bold">→</span>${escHtml(item)}</li>`).join('')}
              </ul>
            </div>
          </div>
        `;
      } else if (data.advancements) {
        whatChangedHTML = `
          <div class="card card-bordered bg-white shadow-sm mb-2.5">
            <div class="card-body p-5">
              <h3 class="text-[0.78rem] font-bold uppercase tracking-wider text-primary flex items-center gap-1.5 mb-3">⚡ What Changed Today</h3>
              <div class="text-sm leading-relaxed text-text-secondary">${data.advancements}</div>
            </div>
          </div>
        `;
      }

      const genTime = new Date().toLocaleString('en-US', {
        timeZone: ISRAEL_TZ,
        hour: 'numeric',
        minute: '2-digit',
        month: 'long',
        day: 'numeric',
        hour12: true
      }) + ' IDT';

      container.innerHTML = `
        <!-- Headline Card -->
        <div class="card card-bordered bg-white shadow-sm overflow-hidden mb-2.5">
          <div class="bg-gradient-to-br from-header-brown to-basalt p-5 sm:p-6 text-white">
            <div class="text-[0.78rem] font-semibold uppercase tracking-wider text-bc-gold mb-1.5">Daily Intelligence Briefing · ${dateFormatted}</div>
            <h2 class="text-2xl sm:text-[1.5rem] font-black leading-tight tracking-tight">${escHtml(data.headline)}</h2>
            <div class="badge ${esc.cls} mt-3 text-base font-extrabold gap-1.5 py-3 px-3.5">${esc.emoji} ${esc.text}</div>
          </div>
        </div>

        ${data.outlook ? `
        <!-- Outlook -->
        <div class="card card-bordered bg-white shadow-sm mb-2.5">
          <div class="card-body p-5">
            <h3 class="text-[0.78rem] font-bold uppercase tracking-wider text-primary flex items-center gap-1.5 mb-3">🔮 Outlook</h3>
            <div class="bg-gradient-to-br from-accent-soft to-[#FFF8F0] border border-[#F5DFC8] rounded-lg p-4 text-sm leading-relaxed text-text-secondary">
              <span class="text-lg mr-1">👁️</span> ${escHtml(data.outlook)}
            </div>
          </div>
        </div>
        ` : ''}

        <!-- Key Events Timeline -->
        <div class="card card-bordered bg-white shadow-sm mb-2.5">
          <div class="card-body p-5">
            <h3 class="text-[0.78rem] font-bold uppercase tracking-wider text-primary flex items-center gap-1.5 mb-3">⏱️ Key Events</h3>
            ${eventsHTML ? `<ul class="timeline timeline-vertical timeline-compact">${eventsHTML}</ul>` : '<p class="text-sm text-text-muted">No key events recorded.</p>'}
          </div>
        </div>

        <!-- Daily Summary -->
        <div class="card card-bordered bg-white shadow-sm mb-2.5">
          <div class="card-body p-5">
            <h3 class="text-[0.78rem] font-bold uppercase tracking-wider text-primary flex items-center gap-1.5 mb-3">📋 Daily Summary</h3>
            <div class="text-sm leading-relaxed text-text-secondary prose prose-sm prose-p:mb-4 prose-headings:mt-6 prose-headings:mb-2 max-w-none">${data.summary || '<p>No summary available.</p>'}</div>
          </div>
        </div>

        ${whatChangedHTML}

        <!-- Data Notes (Collapsible) -->
        <div class="card card-bordered bg-white shadow-sm mb-2.5">
          <div class="collapse collapse-arrow">
            <input type="checkbox" />
            <div class="collapse-title text-[0.72rem] font-semibold text-text-muted min-h-0 py-3 px-5">
              Data Notes
            </div>
            <div class="collapse-content px-5">
              <div class="flex gap-4 flex-wrap pb-2">
                <div class="text-[0.75rem] text-text-muted flex items-center gap-1">📰 <strong class="text-text-secondary font-semibold">${stats.total_articles || '—'}</strong> articles</div>
                <div class="text-[0.75rem] text-text-muted flex items-center gap-1">🌐 <strong class="text-text-secondary font-semibold">${stats.sources_reporting || '—'}</strong> sources</div>
                <div class="text-[0.75rem] text-text-muted flex items-center gap-1">🏆 ${escHtml(stats.most_active_source || '—')} most active</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Footer Nav -->
        <div class="card card-bordered bg-white shadow-sm">
          <div class="card-body p-4 flex flex-col items-center gap-2">
            <div class="text-[0.72rem] text-text-muted font-medium">Briefing generated at ${genTime}</div>
            <div class="flex gap-4 items-center">
              ${prevLink}
              ${nextLink}
            </div>
          </div>
        </div>
      `;

      // Nav link event handlers
      container.querySelectorAll('[data-nav-date]').forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const dateStr = (link as HTMLElement).dataset.navDate;
          if (dateStr) loadBriefing(dateStr);
        });
      });
    }

    init();
  </script>
</Base>
