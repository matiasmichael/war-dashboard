---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import SitrepCard from '../components/SitrepCard.astro';
import DevelopmentsGrid from '../components/DevelopmentsGrid.astro';
import ArticleCard from '../components/ArticleCard.astro';
import FilterBar from '../components/FilterBar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { getLangFromUrl } from '../i18n/utils';
import { t } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);

// Read data at build time
import fs from 'node:fs';
import path from 'node:path';

const dataPath = path.join(process.cwd(), 'src', 'data', 'latest.json');
let articles: any[] = [];
let sourceStats: any[] = [];
let sitrep: any = null;
let developments: any[] | null = null;

if (fs.existsSync(dataPath)) {
  const raw = JSON.parse(fs.readFileSync(dataPath, 'utf-8'));
  articles = raw.articles || [];
  sourceStats = raw.sourceStats || [];
  sitrep = raw.sitrep || null;
  developments = raw.developments || null;
}

// Build top story detection from sitrep
const topHeadlineKeywords = (sitrep?.top_updates || []).map((u: any) => {
  return (u.headline || '').toLowerCase().split(/\s+/).filter((w: string) =>
    w.length >= 4 && !['that','this','with','from','they','have','been','more','also','into','than','said'].includes(w)
  );
});

function isTopStory(title: string): boolean {
  const titleLower = (title || '').toLowerCase();
  for (const keywords of topHeadlineKeywords) {
    if (keywords.length === 0) continue;
    const matches = keywords.filter((kw: string) => titleLower.includes(kw));
    if (matches.length >= 2) return true;
  }
  return false;
}

// Get unique sources for filter bar
const sources = [...new Set(articles.map((a: any) => a.source))];

// Read FEEDS config for filter bar metadata
import feedsData from '../feeds.json';
const feeds = feedsData;

// Toast delay constant
const UPDATE_TOAST_DELAY_MS = 3600000;

const articleCount = `${articles.length} ${t(lang, 'archive.articles')} · ${sourceStats.filter((s: any) => !s.error).length} ${t(lang, 'archive.sources')}`;
const generatedAt = new Date().toISOString();

const liveLabel = t(lang, 'header.live');
const staleLabel = t(lang, 'header.stale');
const lastUpdatedLabel = t(lang, 'header.lastUpdated');
const articlesShownLabel = t(lang, 'filter.articlesShown');
const newUpdatesLabel = t(lang, 'index.newUpdates');
---

<Base title={t(lang, 'index.title')} generatedAt={generatedAt} lang={lang}>
  <Header lang={lang} />

  <div class="max-w-[680px] mx-auto px-3 sm:px-4 pb-12 pt-2">
    <SitrepCard sitrep={sitrep} lang={lang} />
    <DevelopmentsGrid developments={developments} lang={lang} />
    <FilterBar sources={sources} feeds={feeds} articleCount={articleCount} lang={lang} />
    <div id="articles">
      {articles.map((article: any, idx: number) => (
        <ArticleCard article={article} idx={idx} isTopStory={isTopStory(article.title)} lang={lang} />
      ))}
    </div>
  </div>

  <!-- Back to top button -->
  <button class="btn btn-circle btn-primary fixed bottom-8 z-40 shadow-lg text-lg hidden" id="backToTop" style={`bottom: calc(2rem + env(safe-area-inset-bottom, 0px)); ${lang === 'he' ? 'left: 1rem' : 'right: 1rem'}`}>↑</button>

  <!-- Update toast -->
  <div class="toast toast-top toast-center z-50 pointer-events-none" id="updateToastWrapper" style="display:none; top: calc(70px + env(safe-area-inset-top, 0px))" data-delay-ms={String(UPDATE_TOAST_DELAY_MS)}>
    <div class="alert bg-neutral text-neutral-content shadow-xl cursor-pointer rounded-full py-2 px-5 text-[0.82rem] font-medium pointer-events-auto" id="updateToast">{newUpdatesLabel}</div>
  </div>

  <Footer lang={lang} />

  <script define:vars={{ liveLabel, staleLabel, lastUpdatedLabel, articlesShownLabel }}>
    // ===== LIVE TIMESTAMP RE-COMPUTATION =====
    function computeTimeAgo(dateStr) {
      const now = new Date();
      const date = new Date(dateStr);
      const rawDiffMs = now.getTime() - date.getTime();
      const diffMs = Math.max(0, rawDiffMs);
      const diffMins = Math.floor(diffMs / 60000);
      const diffHours = Math.floor(diffMs / 3600000);
      const diffDays = Math.floor(diffMs / 86400000);
      if (diffMins < 1) return 'just now';
      if (diffMins < 60) return diffMins + 'm ago';
      if (diffHours < 24) return diffHours + 'h ago';
      if (diffDays < 7) return diffDays + 'd ago';
      return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
    }

    function refreshAllTimestamps() {
      document.querySelectorAll('.time-ago[data-date]').forEach(function(el) {
        const dateAttr = el.getAttribute('data-date');
        if (dateAttr) el.textContent = computeTimeAgo(dateAttr);
      });
    }

    refreshAllTimestamps();
    setInterval(refreshAllTimestamps, 30000);

    // ===== PAGE FRESHNESS SIGNAL =====
    function updateFreshness() {
      const meta = document.querySelector('meta[name="data-generated-at"]');
      if (!meta) return;
      const generatedAt = new Date(meta.getAttribute('content') || '');
      const now = new Date();
      const diffMs = now.getTime() - generatedAt.getTime();
      const diffMins = Math.floor(diffMs / 60000);
      const pill = document.getElementById('livePill');
      const freshLabel = document.getElementById('headerFreshness');

      if (!pill || !freshLabel) return;

      // User's local time
      const localTimeStr = generatedAt.toLocaleTimeString('en-US', {
        hour: 'numeric',
        minute: '2-digit',
        hour12: true
      });
      // Israel time in parentheses
      const israelTimeStr = generatedAt.toLocaleTimeString('en-US', {
        timeZone: 'Asia/Jerusalem',
        hour: '2-digit',
        minute: '2-digit',
        hour12: false
      });
      freshLabel.textContent = lastUpdatedLabel + ' ' + localTimeStr + ' (' + israelTimeStr + ' 🇮🇱)';

      pill.className = pill.className.replace(/live-pill-\w+/g, '').trim();
      if (diffMins < 15) {
        pill.classList.add('live-pill-fresh');
        pill.textContent = liveLabel;
      } else if (diffMins < 60) {
        pill.classList.add('live-pill-recent');
        pill.textContent = liveLabel;
      } else {
        pill.classList.add('live-pill-stale');
        pill.textContent = staleLabel;
      }
    }
    updateFreshness();
    setInterval(updateFreshness, 30000);

    // ===== SOURCE FILTERS =====
    let activeSourceFilter = 'all';

    function applyFilters() {
      const cards = document.querySelectorAll('.card[data-source]');
      let visible = 0;
      cards.forEach(function(card) {
        const el = card;
        const sourceMatch = activeSourceFilter === 'all' || el.getAttribute('data-source') === activeSourceFilter;

        if (sourceMatch) {
          el.style.display = '';
          visible++;
        } else {
          el.style.display = 'none';
        }
      });
      const countEl = document.getElementById('articleCount');
      if (countEl) countEl.textContent = visible + ' ' + articlesShownLabel;
    }

    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.filter-btn').forEach(b => {
          b.classList.remove('btn-primary');
          b.classList.add('btn-ghost', 'border', 'border-base-300', 'text-text-muted');
        });
        btn.classList.add('btn-primary');
        btn.classList.remove('btn-ghost', 'border', 'border-base-300', 'text-text-muted');
        activeSourceFilter = btn.dataset.source || 'all';
        applyFilters();
      });
    });

    // ===== SHARE BUTTON =====
    document.querySelectorAll('.share-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const el = btn;
        const title = el.dataset.title || '';
        const url = el.dataset.url || '';
        if (navigator.share) {
          navigator.share({ title, url }).catch(() => {});
        } else {
          navigator.clipboard.writeText(url).then(() => {
            el.classList.add('text-success');
            setTimeout(() => el.classList.remove('text-success'), 1500);
          }).catch(() => {});
        }
      });
    });

    // ===== EXPANDABLE ARTICLE CARDS =====
    document.querySelectorAll('.article-card').forEach(card => {
      const el = card;
      const expandArea = el.querySelector('.article-expand');
      const chevron = el.querySelector('.expand-chevron');

      el.addEventListener('click', (e) => {
        const target = e.target;
        if (target.closest('.share-btn') || target.closest('.read-full-btn')) return;

        e.preventDefault();
        e.stopPropagation();

        if (expandArea) {
          const isOpen = el.classList.contains('expanded');
          if (isOpen) {
            el.classList.remove('expanded');
            expandArea.style.maxHeight = '0';
            expandArea.style.opacity = '0';
            if (chevron) chevron.style.transform = 'rotate(0deg)';
          } else {
            el.classList.add('expanded');
            expandArea.style.maxHeight = expandArea.scrollHeight + 'px';
            expandArea.style.opacity = '1';
            if (chevron) chevron.style.transform = 'rotate(180deg)';
          }
        }
      });
    });

    // ===== READ FULL ARTICLE BUTTONS =====
    document.querySelectorAll('.read-full-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const href = btn.dataset.href;
        if (href) window.open(href, '_blank', 'noopener');
      });
    });

    // ===== EXPANDABLE DEVELOPMENT ROWS =====
    document.querySelectorAll('.dev-row').forEach(row => {
      const el = row;
      const expandArea = el.querySelector('.dev-expand');
      const chevron = el.querySelector('.dev-chevron');
      if (!expandArea) return;

      el.addEventListener('click', () => {
        const isOpen = el.classList.contains('dev-expanded');
        if (isOpen) {
          el.classList.remove('dev-expanded');
          expandArea.style.maxHeight = '0';
          expandArea.style.opacity = '0';
          if (chevron) chevron.style.transform = 'rotate(0deg)';
        } else {
          el.classList.add('dev-expanded');
          expandArea.style.maxHeight = expandArea.scrollHeight + 'px';
          expandArea.style.opacity = '1';
          if (chevron) chevron.style.transform = 'rotate(180deg)';
        }
      });
    });

    // ===== BACK TO TOP BUTTON =====
    const backToTopBtn = document.getElementById('backToTop');
    if (backToTopBtn) {
      backToTopBtn.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
      window.addEventListener('scroll', () => {
        if (window.scrollY > 500) {
          backToTopBtn.classList.remove('hidden');
          backToTopBtn.classList.add('flex');
        } else {
          backToTopBtn.classList.add('hidden');
          backToTopBtn.classList.remove('flex');
        }
      });
    }

    // ===== UPDATE TOAST =====
    const updateToast = document.getElementById('updateToast');
    const updateToastWrapper = document.getElementById('updateToastWrapper');
    if (updateToast && updateToastWrapper) {
      updateToast.addEventListener('click', () => location.reload());
      const toastDelayMs = parseInt(updateToastWrapper.dataset.delayMs || '3600000', 10);
      setTimeout(() => {
        updateToastWrapper.style.display = '';
      }, toastDelayMs);
    }
  </script>
</Base>
